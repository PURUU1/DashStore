@model DashStore.ViewModels.HomeViewModel



<div class="container-fluid px-4 py-5">
    <div class="row">
        <!-- Sidebar Filter -->
        <div class="col-lg-3 pe-lg-5 mb-5 mb-lg-0">
                    @foreach(var Category in Model.Categories)
                    {
                <div class="filter-section">
                    @{
                        
                        var name = Category.Name.Replace(" & ", "And").Replace(" ", "");
                        
                    }
                    <div class="filter-section-title" data-bs-toggle="collapse" href="#@name">


                        <form >
                        <button asp-controller="category" asp-action="index" asp-route-id="@Category.Id" class="ShowCategories" style="background-color:transparent;border:none">
                 @Category.Name    <i class="bi bi-chevron-right"></i>

                        </button>
                            </form>
                </div>
                    <div class="collapse  mt-3" id="@name">
                    @* <input type="text" class="form-control filter-search" placeholder="Search"> *@
                    @*     
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="checkbox" checked id="apple">
                        <label class="form-check-label w-100" for="apple">
                             <span class="count-text"></span>
                        </label>
                    </div> *@
                  
                </div>

          
            </div>
                    }
        </div>
        @if (Model.Products != null)
        {
            <!-- Main Product Grid -->
            <div class="col-lg-9">
                <!-- Grid Header -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="results-count">
                    Selected Products: <span>@Model.Products.Count()</span>
                </div>
                <div>
                    <select class="form-select sort-select">
                        <option selected>By rating</option>
                        <option>Price: Low to High</option>
                        <option>Price: High to Low</option>
                        <option>Newest Arrivals</option>
                    </select>
                </div>
            </div>

            <!-- Products row -->
            <div class="row g-4">


                    @foreach(var Product in Model.Products)
                    {
                        
                <!-- Product 1 -->
                <div class="col-sm-6 col-md-4">
                    <div class="product-card">
                        <button class="wishlist-btn"><i class="bi bi-heart"></i></button>
                        <div class="product-img-container">
                            <img src="@Product.ImageUrl" class="product-img" alt="iPhone 14 Pro">
                        </div>
                        <div class="product-title">@Product.Title</div>
                                <div class="product-price">@Product.Price</div>
                        <button class="buy-now-btn">Buy Now</button>
                    </div>
                </div>
                    }

                
           
            </div>
        </div>
        }
    </div>
</div>

