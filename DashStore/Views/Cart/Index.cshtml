@model DashStore.ViewModels.CartViewModel 






<div class="container cart-section " style="height:100%">
    <div class="row gx-lg-5">

        <!-- LEFT COLUMN: Cart Items -->
        <div class="col-lg-7 cart-column mb-5 mb-lg-0">
            <h3 class="fw-bold mb-4">Shopping Cart</h3>

            <!-- Item 1 -->
            @foreach (var CartItem in Model.CartItems)
            {

                <div class="cart-item">
                    <div class="cart-img-box">
                        <img src="@CartItem.ImageUrl" alt="@CartItem.ProductName">
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="item-title">@CartItem.ProductName</h6>
                        @* <p class="item-spec">@CartItem.</p> *@
                        <p class="item-id">#@CartItem.ProductId</p>
                    </div>
                    <div class="qty-price-group d-flex align-items-center">
                        <div class="qty-wrapper me-4">
                            <button class="qty-btn Remove" id="@CartItem.ProductId" onclick="updateQty(this, -1)"><i class="bi bi-dash"></i></button>
                            <input type="number" class="qty-input" value="@CartItem.Count" min="1" id="@CartItem.ProductId">
                            <button class="qty-btn Add" id="@CartItem.ProductId" onclick="updateQty(this, 1) "><i class="bi bi-plus"></i></button>
                        </div>
                        <div class="item-price">$@CartItem.Price</div>

                        <button class="remove-btn cut" id="@CartItem.ProductId"><i class="bi bi-x"></i></button>
                    </div>
                </div>
            }

            <!-- Item 2 -->

        </div>

        <!-- RIGHT COLUMN: Order Summary -->
        @if (@Model.CartItems.Count <= 0)
        {
            <div class="container-fluid">
                <h1 class="display-1">Cart Is Empty</h1>
            </div>
        }
        else
        {

        <div class="col-lg-5 summary-column">
            <h4 class="summary-title pt-1">Order Summary</h4>

            @* <!-- Promo Code -->
            <div class="mb-4">
                <label class="summary-label">Discount code / Promo code</label>
                <input type="text" class="form-control custom-input" placeholder="Code">
            </div>

            <!-- Bonus Card -->
            <div class="mb-5">
                <label class="summary-label">Your bonus card number</label>
                <div class="position-relative">
                    <input type="text" class="form-control custom-input pe-5" placeholder="Enter Card Number">
                    <button class="apply-btn">Apply</button>
                </div>
            </div> *@

            <!-- Cost Breakdown -->
            <div class="summary-row">
                <span class="text-dark">Subtotal</span>
                <span class="text-dark fw-bold">$@Model.SubTotal</span>
            </div>

            <div class="summary-row text-muted">
                <span>Estimated Tax</span>
                <span class="text-dark fw-bold">$@Model.EstimatedTax</span>
            </div>

            <div class="summary-row text-muted">
                <span>Estimated shipping & Handling</span>
                <span class="text-dark fw-bold">$@Model.EstimatedShippingAndHandling</span>
            </div>

            <!-- Total -->
            <div class="summary-row total">
                <span>Total</span>
                <span>$@Model.Total</span>
            </div>

            <form >

                    @if(Model.adreess != null)
                    {
                        
                    <h4 class="summary-title pt-1">Address</h4>

                    <div class=" container">
                        
                        <div class="address-card active">
                            <div class="action-icons">
                                @{
                                    var adress = Model.adreess;
                                }
                                @* <i class="bi bi-pencil" data-bs-toggle="modal"  data-bs-target="#addAddressModal"></i> *@
                                @* <i class="bi bi-pencil edit-address"
                                   data-title="@adress.Title"
                                   data-street="@adress.StreetAddress"
                                   data-city="@adress.City"
                                   data-state="@adress.State"
                                   data-zip="@adress.PostalCode"
                                   data-phone="@adress.PhoneNumber"
                                   data-bs-toggle="modal"
                                   data-bs-target="#addAddressModal">
                                </i> *@
                                
                                    <button class="bi outline-none  bi-pencil edit-address a" asp-controller="Address" asp-action="Index" 
                               style="border:none; background-color:transparent"    >
                                </button>
                                    
                                <i class="bi bi-x-lg remove" id="@adress.AddressId"></i>
                            </div>
                            <div class="form-check">
                                @* <input class="form-check-input" type="radio" name="addressSelect" id="addr1" checked> *@
                                    <label class="form-check-label w-100" for="addr1">
                                        <div class="address-header">

                                            @Model.adreess.StreetAddress <span class="type-badge">@Model.adreess.PostalCode</span>
                                        </div>
                                    </label>
                                </div>
                                <div class="address-details">
                                    @Model.adreess.City ,
                                    @Model.adreess.State<br>
                                    @* @Model.user.Address.City<br> *@
                                    @Model.adreess.PhoneNumber
                                </div>
                        </div>



                    </div>
                        <!-- Checkout Button -->
                        <button class="checkout-btn"
                                asp-controller="Payment" asp-action="index">
                            Do Payment
                        </button>
                    }
                    else
                    {
                        
                    <!-- Checkout Button -->
            <button class="checkout-btn"
                            asp-controller="Cart" asp-action="Checkout">
                        Checkout
                    </button>
                    }
                </form>

        </div>
        }
    </div>
</div>



<div>
</div>



@section Scripts {
    <script>
        $(document).ready(function () {
            

            var qtyInput = document.querySelector(".qty-input");
                   var typingTimer;                
        var doneTypingInterval = 1000;

        
        $(".qty-input").on("input", function(e) {
            e.preventDefault();

            
            var btn = $(this);
            var id = btn.attr("id");
            var count = btn.val();
            var Update = 1;

            
            clearTimeout(typingTimer);

            
            typingTimer = setTimeout(function() {

                

                $.ajax({
                    url: `/Cart/AddToCart/${id}`,
                    type: 'Post',
                    data: {
                        id: id,
                        quatity: count, 
                        Update: Update
                    },
                    success: function (response) {
                        console.log(response);
                        if (response.removeFromCartUi) {
                            btn.closest('.cart-item').fadeOut(300, function() {
                                $(this).remove();
                            });
                        }
                        // alert("Success: " + response.message);

                        var card = btn.closest('.card');
                        card.find(".count").html(response.count);
                        $("#Item-Count").html(response.count);


                        window.location.reload();
                    },
                    error: function (xhr, status, error) {
                        console.error("Error occurred: " + error);
                    }
                });

            }, doneTypingInterval);
        });
        
