@model DashStore.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home Page";
}
<div class="toast-container position-fixed bottom-0 end-0 p-3">
    <div id="cartToast" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body">
                Item's successfully added to your Wishlist!
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<div class="toast-container-2 position-fixed bottom-0 end-0 p-3">
    <div id="cartToast-2" class="toast align-items-center text-bg-success border-0" role="alert" aria-live="assertive" aria-atomic="true">
        <div class="d-flex">
            <div class="toast-body text-danger">
                Item's Removed!
            </div>
            <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<style>
    /* MAGIC FIX 1: Prevent horizontal white space completely */
    body, html {
        /* overflow-x: hidden !important; */
        max-width: 100vw;
    }

    /* MAGIC FIX 2: Hide ugly scrollbar on carousels but keep scroll functionality */
    .product-carousel {
        -ms-overflow-style: none; /* IE and Edge */
        scrollbar-width: none; /* Firefox */
        scroll-behavior: smooth;
    }

        .product-carousel::-webkit-scrollbar {
            display: none; /* Chrome, Safari and Opera */
        }
</style>

