@model DashStore.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home Page";

}










<div class="text-center">

    <main class=" my-1">

        <div class="text-center banner1 d-flex justify-content-center align-items-center">
            <div class="text-White text-start" style="width:50%; height:100%">
                <p>Pro.Beyond.</p>
                <h6 class="display-1">IPhone 14 Pro</h6>
                <p>Created to change everything for the better. For everyone</p>
                <button class="btn btnMain">Shop Now</button>
            </div>
            <img src="~/assets\IphoneImage.png" alt="Alternate Text" />

        </div>

        <div class="container-fluid px-0">
            <div class="row g-0">
                <div class="col-md-6">
                    <div class="row g-0">

                        <div class="col-12 bg-white d-flex align-items-center " style="min-height: 300px;">
                            <img src="~/assets/PlayStation.png" class="img-fluid w-50" alt="PS5">
                            <div class="ms-4">
                                <h2 class="fw-bold">Playstation 5</h2>
                                <p class="text-muted small w-75">Incredibly powerful CPUs, GPUs, and an SSD with integrated I/O...</p>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="row g-0">
                                <div class="col-6  d-flex align-items-center " style="min-height: 250px;background-color:rgb(237, 237, 237)">
                                    <img src="~/assets/hero__gnfk5g59t0qe_xlarge_2x 1.png" class="img-fluid w-50" alt="AirPods">
                                    <div class="ms-3">
                                        <h4 class="fw-bold mb-0">Apple AirPods</h4>
                                        <p class="fw-bold">Max</p>
                                        <p class="small text-muted">Computational audio. Listen, it's powerful.</p>
                                    </div>
                                </div>
                                <div class="col-6  text-white d-flex align-items-center " style="min-height: 250px;background-color:rgb(53, 53, 53)">
                                    <img src="~/assets/image 36.png" class="img-fluid w-50" alt="Vision Pro">
                                    <div class="ms-3">
                                        <h4 class="fw-bold mb-0">Apple</h4>
                                        <p class="fw-bold">Vision Pro</p>
                                        <p class="small text-secondary">An immersive way to experience entertainment.</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>

                <div class="col-md-6  d-flex flex-column justify-content-center p-5 position-relative" style="min-height: 550px;background-color:rgb(237, 237, 237)">
                    <div class="z-1">
                        <h1 class="display-4 fw-light">Macbook <br><strong>Air</strong></h1>
                        <p class="text-muted w-50">The new 15-inch Macbook Air makes room for more of what you love...</p>
                        <button class="btn btn-outline-dark px-4 py-2">Shop Now</button>
                    </div>
                    <img src="~/assets\MacBook Pro 14.png" class="position-absolute end-0 bottom-0 img-fluid " width="300px" alt="Macbook">
                </div>

            </div>
        </div>

        <h5>@ViewBag.Name</h5>

        @* <h5 class="text-center  display-6">All Products</h5> *@
        <div class=" d-flex justify-content-center mb-5" id="All">


            @* <div class="carousel-wrapper"> *@
            <div class="d-flex justify-content-center">
                <!-- Navigation -->
                @* <button class="nav-btn prev-btn" id="prevBtn"><i class="bi bi-chevron-left"></i></button>
                <button class="nav-btn next-btn" id="nextBtn"><i class="bi bi-chevron-right"></i></button> *@

                <!-- Carousel Content -->
                @* <div class="product-carousel" id="carousel"> *@
                <div class=" row">

                    @foreach (var Product in Model.Products)
                    {





                        <!-- Product Card HTML -->
                        <div class="product-card m-2 col-3" style="background-color:">
                            <!-- Wishlist Icon -->
                            @* <div class="wishlist-btn">
                            <i class="bi bi-heart"></i>
                        </div> *@

                            <!-- Image -->
                            <div class="product-img-container">
                                <img src="@Product.ImageUrl" alt="@Product.Title">
                            </div>

                            <!-- Content -->
                            <div class="text-center">
                                <h5 class="product-title">
                                    @Product.Title
                                </h5>

                                <div class="price-tag">@Product.Price</div>
                                <form method="get">
                                    <button class="btn-buy  buyBtn BuyNow " asp-controller="Product"
                                            asp-action="Details"
                                            asp-route-id="@Product.Id" id="@Product.Id">
                                        Buy Now
                                    </button>
                                </form>
                            </div>
                        </div>


                    }
                </div>
            </div>
        </div>





