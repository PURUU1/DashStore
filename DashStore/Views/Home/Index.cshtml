@model DashStore.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>


   <h5>@ViewBag.Name</h5>
        <form method="get">

   <div class="row gx-2 ">

    @foreach(var Product in Model.Products)
    {

        <div class="card m-2" style="width: 18rem;">
            <img src="@Product.ImageUrl" class="card-img-top" alt="Product Image">
            @* <svg aria-label="Placeholder: Image cap" class="bd-placeholder-img card-img-top" height="180" preserveAspectRatio="xMidYMid slice" role="img" width="100%" xmlns="http://www.w3.org/2000/svg"><title>Placeholder</title><rect width="100%" height="100%" fill="#868e96"></rect><text x="50%" y="50%" fill="#dee2e6" dy=".3em">Image Here</text></svg> *@
            <div class="card-body">
                <h5 class="card-title">@Product.Title</h5>
                <p class="card-text">@Product.Description</p>
               
                <h6 class="card-subtitle mb-2 text-body-secondary">@Product.Category.Name</h6>
                @* <a href="#" class="btn btn-primary">$ @Product.Price</a> *@
                    <button  class="btn btn-primary BuyNow" asp-controller="Product"
                       asp-action="Details"
                       asp-route-id="@Product.Id"  id="@Product.Id">Buy Now</button>
            </div>
        </div>
   
    }
   </div>

        </form>



