@section Scripts {
    <script>
        $(document).ready(function() {
            $('.wishlist-btn').click(function (e) {
                            e.preventDefault();

                            var button = $(this);
                            var icon = button.find('i');
                            var productId = button.data('id');

                            $.ajax({
                                url: '/Wishlist/ToggleWishlist',
                                type: 'POST',
                                data: { productId: productId },
                                success: function (response) {
                                    if (response.success) {
                                        if (response.isAdded) {
                                            const toastLiveExample = document.getElementById('cartToast');
                                            const toastBootstrap = bootstrap.Toast.getOrCreateInstance(toastLiveExample);
                                            toastBootstrap.show();
                                            icon.removeClass('bi-heart').addClass('bi-heart-fill');
                                        }
                                        else {
                                            const toastLiveExample = document.getElementById('cartToast-2');
                                            const toastBootstrap = bootstrap.Toast.getOrCreateInstance(toastLiveExample);
                                            toastBootstrap.show();
                                            icon.removeClass('bi-heart-fill').addClass('bi-heart');
                                        }
                                    }
                                },
                                error: function (xhr) {
                                    if (xhr.status === 401) {
                                        alert("Please log in to save items to your wishlist!");
                                        window.location.href = '/Identity/Account/Login';
                                    } else {
                                        console.error("Failed to toggle wishlist.");
                                    }
                                }
                            });
                        });
            // Keep your existing exact logic
        //     const scrollAmount = 360;

        //     $('.next-btn').click(function() {
        //         var targetId = $(this).data('target');
        //         var $carousel = $(targetId);
        //         $carousel.animate({
        //             scrollLeft: $carousel.scrollLeft() + scrollAmount
        //         }, 200);
        //     });

        //     $('.prev-btn').click(function() {
        //         var targetId = $(this).data('target');
        //         var $carousel = $(targetId);
        //         $carousel.animate({
        //             scrollLeft: $carousel.scrollLeft() - scrollAmount
        //         }, 400);
        //     });

                
            console.log("hi")
            const scrollAmount = 360;

            $('.next-btn').click(function() {
                var targetId = $(this).data('target');

                // [0] gets the raw HTML element out of the jQuery object so we can use native scrollBy
                $(targetId)[0].scrollBy({
                    left: scrollAmount,
                    behavior: 'smooth'
                });
            });

            $('.prev-btn').click(function() {
                var targetId = $(this).data('target');

                $(targetId)[0].scrollBy({
                    left: -scrollAmount,
                    behavior: 'smooth'
                });
            });
        });






        window.onload = function() {
          
            document.getElementById('skeleton-container').style.display = 'none';
          
            document.getElementById('real-content').style.display = 'block';
        };


                window.addEventListener("scroll", function () {
              if (document.body.scrollTop > 100 || document.documentElement.scrollTop > 100) {
                backToTopBtn.style.display = "block";
              } else {
                backToTopBtn.style.display = "none";
              }
            });

            
            backToTopBtn.addEventListener("click", function () {
              window.scrollTo({
                top: 0,
                behavior: "smooth"
              });
            });
    </script>
}



